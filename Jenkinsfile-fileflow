pipeline {
  agent any
  options { timestamps() }

  environment {
    BASE = '/var/jenkins_home/fileflow'
  }

  stages {

    stage('Init dirs') {
      steps {
        sh '''
          set -euo pipefail
          mkdir -p "$BASE"/{inbox,processing/{invoices,messages,reports,texts},fe,bo,outbox,archive,logs}
          echo "Könyvtárstruktúra:"
          ls -l "$BASE" || true
        '''
      }
    }

    stage('Route files') {
      steps {
        sh '''
          set -euo pipefail

          shopt -s nullglob
          has_any=0

          for f in "$BASE/inbox"/*; do
            has_any=1
            name="$(basename "$f")"
            ext="${name##*.}"

            case "$ext" in
              inv)
                type="invoices"; target_side="bo"
                ;;
              msg)
                type="messages"; target_side="fe"
                ;;
              rpt)
                type="reports"; target_side="bo"
                ;;
              txt)
                type="texts"; target_side="fe"
                ;;
              *)
                echo "Ismeretlen kiterjesztés, kihagyva: $name"
                continue
                ;;
            esac

            mkdir -p "$BASE/processing/$type"
            mv "$f" "$BASE/processing/$type/$name"

            # (opcionális) rezidens másolat a FE/BO mappákban megfigyeléshez
            cp -f "$BASE/processing/$type/$name" "$BASE/$target_side/" || true

            echo "Routolva: $name  -> processing/$type  (+ $target_side megfigyelés)"
          done

          if [ "$has_any" -eq 0 ]; then
            echo "Nincs mit mozgatni az inbox-ban."
          fi

          echo "Állapot a routing után:"
          echo "# inbox";      ls -l "$BASE/inbox"      || true
          echo "# processing"; ls -l "$BASE/processing" || true
          echo "# fe";         ls -l "$BASE/fe"         || true
          echo "# bo";         ls -l "$BASE/bo"         || true
        '''
      }
    }

    stage('Simulate containers (process -> outbox)') {
      steps {
        sh '''
          set -euo pipefail

          for type in invoices messages reports texts; do
            OUT="$BASE/outbox/${type}.txt"
            : > "$OUT"   # üresítjük a kimeneti fájlt futás elején

            # végigmegyünk a konkrét fájlokon; üres mappa esetén továbblépünk
            for f in "$BASE/processing/$type"/*; do
              [ -e "$f" ] || continue      # nincs találat
              [ -f "$f" ] || continue      # csak fájlokra dolgozunk

              echo ">> $(basename "$f")" >> "$OUT"
              cat "$f" >> "$OUT"
              printf "\\n----\\n" >> "$OUT"
            done
          done

          echo "Outbox tartalma:"
          ls -l "$BASE/outbox" || true
        '''
      }
    }

    stage('Nightly package (optional)') {
      when {
        expression { return params.NIGHTLY?.toString() == 'true' }
      }
      steps {
        sh '''
          set -euo pipefail
          ts="$(date +%Y%m%d-%H%M%S)"
          pkg="$BASE/archive/pkg-$ts.tgz"

          # ha üres az outbox, a tar üres tgz-t csinál – ez nekünk oké
          tar -czf "$pkg" -C "$BASE/outbox" . || true
          echo "Csomag készült: $pkg"

          # opcionális takarítás
          find "$BASE/outbox" -type f -delete || true

          echo "Archive:"
          ls -lh "$BASE/archive" || true
        '''
      }
    }
  }

  post {
    success {
      echo 'Fileflow pipeline: SUCCESS'
    }
    failure {
      echo 'Fileflow pipeline: FAILURE'
    }
    always {
      sh 'echo "Kész."'
    }
  }
}

properties([
  parameters([
    booleanParam(name: 'NIGHTLY', defaultValue: false, description: 'Éjszakai csomagolás és outbox ürítés')
  ])
])
